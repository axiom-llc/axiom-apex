  "templates": [
    {
      "name": "compliance-audit",
      "file": "compliance-audit.sh",
      "category": "operations",
      "description": "Automated regulatory compliance audit — SOC2, HIPAA, PCI-DSS, GDPR, ISO 27001",
      "version": "1.0.0",
      "cron": [
        {"schedule": "0 2 * * *",   "command": "nightly"},
        {"schedule": "0 7 * * 1",   "command": "weekly"},
        {"schedule": "0 6 1 * *",   "command": "audit SOC2"}
      ],
      "config": [
        {"key": "ORG_NAME",    "required": true,  "description": "Your organization name"},
        {"key": "FRAMEWORKS",  "required": false, "default": "SOC2 HIPAA", "description": "Space-separated list of frameworks to audit"}
      ],
      "commands": ["nightly", "audit <framework>", "evidence <control>", "remediation", "weekly"],
      "target_buyer": "Series A+ startups, healthcare SMBs, any org pursuing SOC2",
      "pricing_model": "per-audit or monthly retainer",
      "revenue_tier": "high"
    },
    {
      "name": "cybersecurity",
      "file": "cybersecurity.sh",
      "category": "operations",
      "description": "Threat intelligence, vulnerability scanning, incident response, morning security brief",
      "version": "1.0.0",
      "cron": [
        {"schedule": "*/30 * * * *", "command": "pulse"},
        {"schedule": "0 6 * * 1-5",  "command": "morning"},
        {"schedule": "0 2 * * *",    "command": "threat-sweep"},
        {"schedule": "0 3 * * *",    "command": "vuln-scan"},
        {"schedule": "0 7 * * 1",    "command": "weekly"}
      ],
      "config": [
        {"key": "ORG_NAME",    "required": true,  "description": "Your organization name"},
        {"key": "ASSETS_FILE", "required": true,  "default": "~/.config/apex/sec_assets", "description": "One IP/domain per line"}
      ],
      "commands": ["pulse", "morning", "threat-sweep", "vuln-scan", "incident <desc> [severity]", "weekly"],
      "target_buyer": "SMBs without dedicated security team, MSPs",
      "pricing_model": "monthly managed service add-on",
      "revenue_tier": "high"
    },
